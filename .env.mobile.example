VITE_API_BASE_URL=https://your-nutriai-backend.example.com

# Local emulator/dev alternatives:
# Android emulator can reach the host machine with:
# VITE_API_BASE_URL=http://10.0.2.2:4001
#
# iOS simulator can usually reach the host machine with:
# VITE_API_BASE_URL=http://localhost:4001
#
# Real phones need a backend URL reachable from the device, preferably HTTPS.
