DATABASE_URL=postgres://postgres:password@localhost:5432/nutriai
DATABASE_SSL=false
DATABASE_SCHEMA=nutriai
PORT=4001
CORS_ORIGIN=http://localhost:5176
LOCAL_USER_EMAIL=local@nutriai.app
LOCAL_USER_NAME=Local User

# Optional. Gemini is preferred for AI/photo/audio features.
# Without an AI key, the app returns safe fallback data instead of failing.
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash-lite

# Optional fallback if Gemini is not configured.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Frontend/mobile API URL. Keep empty for Vite dev proxy in browser.
# For a real phone app, set this to a deployed HTTPS backend URL.
VITE_API_BASE_URL=
